> 
> ### ** Examples
> 
> # Two-sample t-test
> men <- rnorm(100, mean = 5, sd = 1)
> women <- rnorm(100, mean = 4.8, sd = 1)
> t.test2(men, women)
Two sample Welch t-test

   men women men-women  ci  ci.L  ci.H    t    df p.value N(men) N(women)
 5.109 4.762     0.347 95% 0.088 0.606 2.64 197.2   .0089    100      100

APA Style:
t(197.2) = 2.64, p = .0089
> 
> # Paired t-test
> x <- rnorm(50, mean = 5, sd = 1)
> y <- rnorm(50, mean = 5.2, sd = 1)
> t.test2(x, y, paired = TRUE)
Two sample paired t-test

     x     y    x-y  ci   ci.L  ci.H      t df p.value  N r(x,y)
 4.969 5.291 -0.322 95% -0.718 0.074 -1.634 49   .1087 50  0.099

APA Style:
t(49.0) = -1.63, p = .1087
> 
> # One-sample t-test
> data <- rnorm(100, mean = 5, sd = 1)
> t.test2(data, mu = 0)
One sample Student t-test

  mean  ci  ci.L  ci.H     t df p.value   N
 5.052 95% 4.855 5.248 50.94 99  <.0001 100

APA Style:
t(99.0) = 50.94, p < .0001
> 
> # Formula syntax
> data <- data.frame(y = rnorm(100), group = rep(c("A", "B"), 50))
> t.test2(y ~ group, data = data)
Two sample Welch t-test

     A     B    A-B  ci   ci.L ci.H     t   df p.value N(A) N(B)
 5.162 5.419 -0.256 95% -0.382 0.55 0.358 97.8   .7209   25   25

APA Style:
t(97.8) = 0.36, p = .7209

note: 'A' is missing 25 of 50 values, while 'B' is missing 25 of 50
