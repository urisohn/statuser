> # CLUSTERED STANDARD ERRORS
> # When observations are grouped (e.g., students within schools),
> # use clusters to account for within-group correlation
> set.seed(123)
> n_clusters <- 20
> n_per_cluster <- 15
> cluster_id <- rep(1:n_clusters, each = n_per_cluster)
> cluster_effect <- rnorm(n_clusters, sd = 2)[cluster_id]
> x <- rnorm(n_clusters * n_per_cluster)
> y <- 1 + 0.5 * x + cluster_effect + rnorm(n_clusters * n_per_cluster)
> mydata <- data.frame(y = y, x = x, cluster_id = cluster_id)
> 
> # Clustered SE (CR2) - note the SE.cluster column in output
> lm2(y ~ x, data = mydata, clusters = cluster_id)
Call: lm2(formula = y ~ x, data = mydata, clusters = cluster_id)

            estimate SE.cluster SE.robust SE.classical t.value df    p.value
intercept   1.279**    0.442      0.125      0.125     2.893    19.0   .0093
x           0.396**    0.083      0.132      0.131     4.776    17.5   .0002
            std.estimate   mean missing red.flag
intercept         --        --    --        --  
x              0.173     0.022    0         --  

N = 300  | missing = 0  | R² = 0.030  | SE type: CR2 (cluster)

Notes:
  - ** p<.01 (based on SE.cluster)
  - SE.robust (HC3) used only to contrast with SE.classical to flag observations
  - std.estimate is the standardized coefficient: beta = b * sd(x) / sd(y)
  - mean: for numeric variables, mean of x; for factors, % of observations
  - missing: number of observations excluded due to missing values
  - red.flag: none (robust and classical SE are similar)
  - To avoid these notes, lm2(..., notes=FALSE)
> 
> # FIXED EFFECTS
> # Use fixed_effects to absorb group-level variation (e.g., firm or year effects)
> # This is useful for panel data or when you have many fixed effect levels
> set.seed(456)
> n_firms <- 30
> n_years <- 5
> firm_id <- rep(1:n_firms, each = n_years)
> year <- rep(2018:2022, times = n_firms)
> firm_effect <- rnorm(n_firms, sd = 3)[firm_id]
> x <- rnorm(n_firms * n_years)
> y <- 2 + 0.8 * x + firm_effect + rnorm(n_firms * n_years)
> panel <- data.frame(y = y, x = x, firm_id = factor(firm_id), year = factor(year))
> 
> # Absorb firm fixed effects (coefficient on x is estimated, firm dummies are not shown)
> lm2(y ~ x, data = panel, fixed_effects = ~ firm_id)
Call: lm2(formula = y ~ x, data = panel, fixed_effects = ~firm_id)

            estimate  SE.robust SE.classical t.value p.value std.estimate
intercept   [dropped]   --         --        --       --        --       
x           0.727**     0.085      0.082     8.527    <.0001    0.191    
firm_id     df=30       --         --        --       --        --       
              mean  missing red.flag
intercept   --        --        --  
x           -0.066    0         --  
firm_id     --        0         --  

N = 150  | missing = 0  | df = 119  | R² = 0.951  | SE type: HC3 

Notes:
  - ** p<.01 (based on SE.robust)
  - std.estimate is the standardized coefficient: beta = b * sd(x) / sd(y)
  - mean: for numeric variables, mean of x; for factors, % of observations
  - missing: number of observations excluded due to missing values
  - red.flag: none (robust and classical SE are similar)
  - firm_id were entered as absorbed fixed effects; df is the number of unique values.
  - To avoid these notes, lm2(..., notes=FALSE)
> 
